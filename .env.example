# Algoguido Technologies — Enterprise Monorepo

## Environment Variables

# Database
DATABASE_URL=postgresql://algoguido:algoguido_pass@localhost:5432/algoguido_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# API
API_PORT=4000
API_PREFIX=api
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Web App
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin App
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:4000/api

# AI (provider TBD)
AI_PROVIDER=gemini
AI_API_KEY=your-ai-api-key

# Email (provider TBD)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@algoguido.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@algoguido.com

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key

# App
NODE_ENV=development

# Seed Endpoint Secret (set a strong random string in production)
SEED_SECRET=change-me-to-a-strong-random-secret
