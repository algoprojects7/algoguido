{
  "name": "@algoguido/config",
  "version": "1.0.0",
  "private": true,
  "description": "Shared configuration — ESLint, TSConfig, Tailwind, environment validation",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./eslint": "./eslint.config.mjs",
    "./tailwind": "./tailwind.config.ts",
    "./tsconfig/*.json": "./tsconfig/*.json"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.0",
    "tailwindcss": "^3.4.3"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
