generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String
  name           String
  avatar         String?
  role           Role           @default(VIEWER)
  isActive       Boolean        @default(true)
  lastLoginAt    DateTime?
  lastLoginIp    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  auditLogs      AuditLog[]
  blogs          Blog[]         @relation("BlogAuthor")
  leadActivities LeadActivity[]
  leadNotes      LeadNote[]
  refreshTokens  RefreshToken[]

  @@map("admin_users")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  group       String
  createdAt   DateTime @default(now())

  @@map("permissions")
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model AuditLog {
  id        String    @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ip        String?
  userAgent String?
  createdAt DateTime  @default(now())
  user      AdminUser @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Product {
  id           String           @id @default(cuid())
  name         String
  slug         String           @unique
  tagline      String
  description  String
  icon         String?
  image        String?
  categoryId   String
  technologies String[]
  isActive     Boolean          @default(true)
  sortOrder    Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  features     ProductFeature[]
  category     ProductCategory  @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([slug])
  @@map("products")
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("product_categories")
}

model ProductFeature {
  id          String  @id @default(cuid())
  productId   String
  title       String
  description String
  icon        String?
  sortOrder   Int     @default(0)
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_features")
}

model EnterpriseService {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String
  longDescription String?
  icon            String?
  image           String?
  category        String
  features        String[]
  technologies    String[]
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@map("enterprise_services")
}

model ClientProject {
  id           String         @id @default(cuid())
  title        String
  slug         String         @unique
  client       String
  description  String
  caseStudy    String?
  technologies String[]
  category     String
  isFeatured   Boolean        @default(false)
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  images       ProjectImage[]

  @@index([slug])
  @@map("client_projects")
}

model ProjectImage {
  id        String        @id @default(cuid())
  projectId String
  url       String
  alt       String
  isPrimary Boolean       @default(false)
  sortOrder Int           @default(0)
  project   ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_images")
}

model Blog {
  id             String       @id @default(cuid())
  title          String
  slug           String       @unique
  excerpt        String
  content        String
  coverImage     String?
  authorId       String
  categoryId     String
  tags           String[]
  seoTitle       String?
  seoDescription String?
  isPublished    Boolean      @default(false)
  publishedAt    DateTime?
  viewCount      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  author         AdminUser    @relation("BlogAuthor", fields: [authorId], references: [id])
  category       BlogCategory @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([authorId])
  @@index([categoryId])
  @@index([isPublished, publishedAt])
  @@map("blogs")
}

model BlogCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  blogs       Blog[]

  @@map("blog_categories")
}

model MediaLibrary {
  id         String    @id @default(cuid())
  name       String
  url        String
  type       MediaType
  mimeType   String
  size       Int
  alt        String?
  uploadedBy String
  createdAt  DateTime  @default(now())

  @@index([type])
  @@map("media_library")
}

model Page {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String?
  seoTitle    String?
  seoDesc     String?
  isPublished Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  sections    PageSection[]

  @@map("pages")
}

model PageSection {
  id        String  @id @default(cuid())
  pageId    String
  type      String
  title     String?
  content   Json?
  sortOrder Int     @default(0)
  page      Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@map("page_sections")
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  designation String
  company     String
  content     String
  avatar      String?
  rating      Int      @default(5)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("testimonials")
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logo      String
  url       String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("partners")
}

model Lead {
  id         String         @id @default(cuid())
  name       String
  email      String
  phone      String?
  company    String?
  stage      LeadStage      @default(NEW)
  source     String         @default("WEBSITE")
  score      Int?
  value      Float?
  assignedTo String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  activities LeadActivity[]
  notes      LeadNote[]

  @@index([stage])
  @@index([email])
  @@index([createdAt])
  @@map("leads")
}

model LeadActivity {
  id          String    @id @default(cuid())
  leadId      String
  type        String
  description String
  userId      String
  createdAt   DateTime  @default(now())
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        AdminUser @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@map("lead_activities")
}

model LeadNote {
  id        String    @id @default(cuid())
  leadId    String
  content   String
  authorId  String
  createdAt DateTime  @default(now())
  author    AdminUser @relation(fields: [authorId], references: [id])
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_notes")
}

model DemoRequest {
  id            String   @id @default(cuid())
  product       String
  name          String
  company       String
  email         String
  phone         String?
  preferredDate String?
  preferredTime String?
  requirements  String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("demo_requests")
}

model ContactMessage {
  id        String    @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  subject   String
  message   String
  isRead    Boolean   @default(false)
  repliedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([isRead])
  @@map("contact_messages")
}

model Payment {
  id                String        @id @default(cuid())
  razorpayOrderId   String        @unique
  razorpayPaymentId String?       @unique
  razorpaySignature String?
  amount            Int
  currency          String        @default("INR")
  status            PaymentStatus @default(CREATED)
  description       String?
  customerEmail     String
  customerName      String
  customerPhone     String?
  metadata          Json?
  invoiceId         String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  invoice           Invoice?      @relation(fields: [invoiceId], references: [id])

  @@index([status])
  @@index([customerEmail])
  @@index([createdAt])
  @@map("payments")
}

model PaymentPlan {
  id             String         @id @default(cuid())
  name           String
  razorpayPlanId String         @unique
  amount         Int
  currency       String         @default("INR")
  interval       PlanInterval
  description    String?
  features       String[]
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  subscriptions  Subscription[]

  @@map("payment_plans")
}

model Subscription {
  id                     String             @id @default(cuid())
  razorpaySubscriptionId String             @unique
  planId                 String
  customerEmail          String
  customerName           String
  status                 SubscriptionStatus @default(CREATED)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  plan                   PaymentPlan        @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([customerEmail])
  @@index([status])
  @@map("subscriptions")
}

model Invoice {
  id                String        @id @default(cuid())
  razorpayInvoiceId String?       @unique
  invoiceNumber     String        @unique
  amount            Int
  currency          String        @default("INR")
  status            InvoiceStatus @default(DRAFT)
  customerEmail     String
  customerName      String
  customerCompany   String?
  lineItems         Json
  notes             String?
  dueDate           DateTime?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  payments          Payment[]

  @@index([status])
  @@index([customerEmail])
  @@map("invoices")
}

model RazorpayWebhook {
  id        String   @id @default(cuid())
  eventType String
  payload   Json
  processed Boolean  @default(false)
  error     String?
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([processed])
  @@map("razorpay_webhooks")
}

model EducationTrack {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  description  String
  type         ApplicationType
  duration     String
  requirements String[]
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  applications Application[]

  @@map("education_tracks")
}

model Application {
  id           String                @id @default(cuid())
  trackId      String
  type         ApplicationType
  name         String
  email        String
  phone        String
  university   String?
  semester     String?
  department   String?
  skills       String[]
  portfolioUrl String?
  message      String?
  status       ApplicationStatus     @default(PENDING)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  documents    ApplicationDocument[]
  track        EducationTrack        @relation(fields: [trackId], references: [id])
  interviews   InterviewSchedule[]

  @@index([trackId])
  @@index([status])
  @@index([email])
  @@map("applications")
}

model ApplicationDocument {
  id            String      @id @default(cuid())
  applicationId String
  name          String
  url           String
  type          String
  size          Int
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_documents")
}

model InterviewSchedule {
  id            String      @id @default(cuid())
  applicationId String
  scheduledAt   DateTime
  duration      Int         @default(30)
  location      String?
  meetingLink   String?
  notes         String?
  status        String      @default("SCHEDULED")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("interview_schedule")
}

model TeamMember {
  id          String  @id @default(cuid())
  name        String
  designation String
  bio         String?
  avatar      String?
  email       String?
  linkedin    String?
  github      String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  @@map("team_members")
}

model Career {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  department   String
  location     String
  type         String
  experience   String?
  description  String
  requirements String[]
  benefits     String[]
  salary       String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("careers")
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("faqs")
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  type        String   @default("STRING")
  group       String   @default("general")
  description String?
  updatedAt   DateTime @updatedAt

  @@index([group])
  @@map("settings")
}

model Menu {
  id        String  @id @default(cuid())
  label     String
  href      String
  parentId  String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  location  String  @default("header")
  parent    Menu?   @relation("MenuChildren", fields: [parentId], references: [id])
  children  Menu[]  @relation("MenuChildren")

  @@index([parentId])
  @@map("menus")
}

model ChatbotConversation {
  id        String           @id @default(cuid())
  sessionId String
  visitorIp String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  ChatbotMessage[]

  @@index([sessionId])
  @@map("chatbot_conversations")
}

model ChatbotMessage {
  id             String              @id @default(cuid())
  conversationId String
  role           String
  content        String
  metadata       Json?
  createdAt      DateTime            @default(now())
  conversation   ChatbotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("chatbot_messages")
}

model AILog {
  id        String   @id @default(cuid())
  module    String
  input     Json
  output    Json
  tokens    Int?
  latencyMs Int?
  error     String?
  createdAt DateTime @default(now())

  @@index([module])
  @@index([createdAt])
  @@map("ai_logs")
}

model Recommendation {
  id        String   @id @default(cuid())
  sessionId String
  type      String
  entityId  String
  score     Float
  reason    String?
  isClicked Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("recommendations")
}

model PageView {
  id        String         @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  sessionId String
  createdAt DateTime       @default(now())
  session   VisitorSession @relation(fields: [sessionId], references: [id])

  @@index([path])
  @@index([sessionId])
  @@index([createdAt])
  @@map("page_views")
}

model VisitorSession {
  id        String     @id @default(cuid())
  ip        String
  country   String?
  city      String?
  device    String?
  browser   String?
  os        String?
  startedAt DateTime   @default(now())
  endedAt   DateTime?
  pageViews PageView[]

  @@index([startedAt])
  @@map("visitor_sessions")
}

model Download {
  id        String   @id @default(cuid())
  fileName  String
  fileType  String
  fileSize  Int
  ip        String?
  createdAt DateTime @default(now())

  @@map("downloads")
}

model EventLog {
  id        String   @id @default(cuid())
  event     String
  category  String
  label     String?
  value     Float?
  sessionId String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([category])
  @@index([createdAt])
  @@map("event_logs")
}

model Certificate {
  id            String   @id @default(cuid())
  certificateNo String   @unique @map("certificate_no")
  candidateName String   @map("candidate_name")
  course        String
  grade         String
  duration      String
  dateOfIssue   DateTime @map("date_of_issue")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("certificates")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

enum PlanInterval {
  daily
  weekly
  monthly
  yearly
}

enum SubscriptionStatus {
  CREATED
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
  EXPIRED
}

enum ApplicationType {
  INTERNSHIP
  RESEARCH
  TRAINING
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  INTERVIEW
  SELECTED
  REJECTED
}
