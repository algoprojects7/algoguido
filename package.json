{
  "name": "algoguido",
  "version": "1.0.0",
  "private": true,
  "description": "Algoguido Technologies — Enterprise Monorepo",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "@nestjs/core",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @algoguido/db prisma:generate",
    "db:migrate": "pnpm --filter @algoguido/db prisma:migrate:dev",
    "db:push": "pnpm --filter @algoguido/db prisma:db:push",
    "db:seed": "pnpm --filter @algoguido/db prisma:db:seed",
    "db:studio": "pnpm --filter @algoguido/db prisma:studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.3.0",
    "rimraf": "^5.0.0"
  }
}
